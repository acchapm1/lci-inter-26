#!/usr/bin/env python3
from __future__ import print_function

import os
import sys
import re
import hashlib
import shutil
from datetime import datetime

SNAPSHOT_DIRNAME = ".snapshot"
HASH_CHUNK_SIZE = 1024 * 1024


def eprint(msg):
    sys.stderr.write(msg + "\n")


def usage():
    print(
        "Usage:\n"
        "  rewind TARGET\n"
        "  rewind --restore=N TARGET\n"
        "\n"
        "TARGET may be a file or a directory in the current working directory.\n"
        "\n"
        "Examples:\n"
        "  rewind .bashrc\n"
        "  rewind --restore=2 .bashrc\n"
        "  rewind mydir\n"
        "  rewind --restore=1 mydir\n"
    )


def md5sum_file(path):
    h = hashlib.md5()
    with open(path, "rb") as f:
        while True:
            chunk = f.read(HASH_CHUNK_SIZE)
            if not chunk:
                break
            h.update(chunk)
    return h.hexdigest()


def human_size(num_bytes):
    units = ["B", "KB", "MB", "GB", "TB"]
    size = float(num_bytes)
    idx = 0
    while size >= 1024.0 and idx < len(units) - 1:
        size /= 1024.0
        idx += 1
    if idx == 0:
        return "%d %s" % (int(size), units[idx])
    return "%.1f %s" % (size, units[idx])


def get_snapshot_root(cwd):
    return os.path.join(cwd, SNAPSHOT_DIRNAME)


def _is_int_token(s):
    try:
        int(s)
        return True
    except ValueError:
        return False


def _try_parse_date_token(token):
    """
    Try common single-token date forms.
    Returns datetime or None.
    """
    for fmt in ("%Y-%m-%d", "%Y_%m_%d"):
        try:
            return datetime.strptime(token, fmt)
        except ValueError:
            pass
    return None


def _try_parse_datetime_two_tokens(date_token, time_token):
    """
    Try common two-token date+time forms.
    Returns datetime or None.
    """
    combos = [
        ("%Y-%m-%d", "%H:%M"),
        ("%Y-%m-%d", "%H:%M:%S"),
        ("%Y_%m_%d", "%H:%M"),
        ("%Y_%m_%d", "%H:%M:%S"),
    ]

    for dfmt, tfmt in combos:
        try:
            return datetime.strptime(date_token + " " + time_token, dfmt + " " + tfmt)
        except ValueError:
            pass
    return None


def _try_parse_split_tokens(tokens, i):
    """
    Try parsing tokens[i:i+3] as YYYY MM DD and optionally the next 1-3 tokens
    as HH MM SS.

    Returns:
      (dt, consumed_count) or (None, 0)
    """
    if i + 2 >= len(tokens):
        return None, 0

    y, m, d = tokens[i], tokens[i + 1], tokens[i + 2]
    if not (_is_int_token(y) and _is_int_token(m) and _is_int_token(d)):
        return None, 0

    if len(y) != 4:
        return None, 0

    try:
        year = int(y)
        month = int(m)
        day = int(d)
        dt = datetime(year, month, day)
    except ValueError:
        return None, 0

    consumed = 3

    # Try HH MM SS
    if i + 5 < len(tokens):
        hh, mm, ss = tokens[i + 3], tokens[i + 4], tokens[i + 5]
        if _is_int_token(hh) and _is_int_token(mm) and _is_int_token(ss):
            try:
                dt = datetime(year, month, day, int(hh), int(mm), int(ss))
                return dt, 6
            except ValueError:
                pass

    # Try HH MM
    if i + 4 < len(tokens):
        hh, mm = tokens[i + 3], tokens[i + 4]
        if _is_int_token(hh) and _is_int_token(mm):
            try:
                dt = datetime(year, month, day, int(hh), int(mm), 0)
                return dt, 5
            except ValueError:
                pass

    return dt, consumed


def parse_snapshot_date(name):
    """
    Parse a snapshot directory name without regex.

    Supported examples:
      ScheduleName_duration_2026-04-08_12:00
      2026_03_27_4144127
      2026_04_09
      2026_04_09_12_30_00
      foo_bar_2026_04_09
      foo_bar_2026-04-09_12:30

    Returns:
      {
        "dt": datetime,
        "suffix": int,
        "display": str,
      }
    or None if no recognizable date was found.

    Notes:
    - A trailing numeric token after the date/time is treated as an ordering suffix.
    - For names like 2026_03_27_4144127, dt is 2026-03-27 00:00:00 and suffix is 4144127.
    """
    tokens = name.split("_")

    best = None

    for i in range(len(tokens)):
        # Case 1: single token date, e.g. "2026-04-08"
        dt = _try_parse_date_token(tokens[i])
        if dt is not None:
            consumed = 1

            # Optional next token as time, e.g. "12:00" or "12:00:00"
            if i + 1 < len(tokens):
                dt2 = _try_parse_datetime_two_tokens(tokens[i], tokens[i + 1])
                if dt2 is not None:
                    dt = dt2
                    consumed = 2

            suffix = 0
            next_index = i + consumed
            if next_index < len(tokens) and _is_int_token(tokens[next_index]):
                suffix = int(tokens[next_index])

            candidate = {
                "dt": dt,
                "suffix": suffix,
                "display": dt.strftime("%Y-%m-%d %H:%M:%S"),
            }

            if best is None or (candidate["dt"], candidate["suffix"]) > (best["dt"], best["suffix"]):
                best = candidate

        # Case 2: split tokens date/time, e.g. 2026_03_27 or 2026_03_27_12_30_00
        dt, consumed = _try_parse_split_tokens(tokens, i)
        if dt is not None:
            suffix = 0
            next_index = i + consumed
            if next_index < len(tokens) and _is_int_token(tokens[next_index]):
                suffix = int(tokens[next_index])

            candidate = {
                "dt": dt,
                "suffix": suffix,
                "display": dt.strftime("%Y-%m-%d %H:%M:%S"),
            }

            if best is None or (candidate["dt"], candidate["suffix"]) > (best["dt"], best["suffix"]):
                best = candidate

    return best


def list_snapshot_dirs(snapshot_root):
    if not os.path.isdir(snapshot_root):
        return []

    entries = []
    for name in os.listdir(snapshot_root):
        full = os.path.join(snapshot_root, name)
        if not os.path.isdir(full):
            continue

        parsed = parse_snapshot_date(name)
        if parsed is None:
            continue

        entries.append({
            "name": name,
            "path": full,
            "date": parsed["display"],
            "dt": parsed["dt"],
            "suffix": parsed["suffix"],
        })

    entries.sort(key=lambda x: (x["dt"], x["suffix"], x["name"]), reverse=True)
    return entries

def list_regular_files_nonrecursive(dirpath):
    files = {}
    if not os.path.isdir(dirpath):
        return files

    for name in os.listdir(dirpath):
        full = os.path.join(dirpath, name)
        if os.path.isfile(full):
            files[name] = {
                "path": full,
                "size": os.path.getsize(full),
                "md5": None,
            }
    return files


def compute_md5_map(file_map):
    for name in file_map:
        if file_map[name]["md5"] is None:
            file_map[name]["md5"] = md5sum_file(file_map[name]["path"])
    return file_map


def parse_args(argv):
    restore_index = None
    target = None

    for arg in argv[1:]:
        if arg.startswith("--restore="):
            value = arg.split("=", 1)[1]
            try:
                restore_index = int(value)
            except ValueError:
                eprint("Error: --restore must be an integer.")
                return None, None, 1
        elif arg in ("--help", "-h"):
            usage()
            return None, None, 0
        elif arg.startswith("-"):
            eprint("Error: unknown option: %s" % arg)
            return None, None, 1
        else:
            if target is not None:
                eprint("Error: only one target is allowed.")
                return None, None, 1
            target = arg

    if target is None:
        usage()
        return None, None, 1

    return target, restore_index, None


# ---------------- FILE MODE ----------------

def build_file_records(cwd, name):
    current_path = os.path.join(cwd, name)
    if os.path.isfile(current_path):
        current_record = {
            "where": "current",
            "label": "CURRENT",
            "path": current_path,
            "exists": True,
            "size": os.path.getsize(current_path),
            "md5": md5sum_file(current_path),
            "date": "CURRENT",
        }
    else:
        current_record = {
            "where": "current",
            "label": "CURRENT",
            "path": current_path,
            "exists": False,
            "size": None,
            "md5": None,
            "date": "CURRENT",
        }

    snapshot_records = []
    snapshot_dirs = list_snapshot_dirs(get_snapshot_root(cwd))
    for snap in snapshot_dirs:
        candidate = os.path.join(snap["path"], name)
        rec = {
            "where": "snapshot",
            "label": snap["name"],
            "path": candidate,
            "exists": os.path.isfile(candidate),
            "size": None,
            "md5": None,
            "date": snap["date"],
        }
        if rec["exists"]:
            rec["size"] = os.path.getsize(candidate)
            rec["md5"] = md5sum_file(candidate)
        snapshot_records.append(rec)

    distinct_versions = []
    seen_md5 = set()

    if current_record["exists"] and current_record["md5"] not in seen_md5:
        distinct_versions.append(current_record)
        seen_md5.add(current_record["md5"])

    for rec in snapshot_records:
        if not rec["exists"]:
            continue
        if rec["md5"] in seen_md5:
            continue
        distinct_versions.append(rec)
        seen_md5.add(rec["md5"])

    return current_record, snapshot_records, distinct_versions


def print_file_check(cwd, name):
    current_record, snapshot_records, distinct_versions = build_file_records(cwd, name)

    print("Type: file")
    print("Target: %s" % name)
    print("Working directory: %s" % cwd)
    print("")

    if current_record["exists"]:
        print("Current file: PRESENT")
        print("  Size: %s" % human_size(current_record["size"]))
        print("  MD5: %s" % current_record["md5"])
    else:
        print("Current file: NOT PRESENT")
    print("")

    print("Distinct versions available (most recent first):")
    if not distinct_versions:
        print("  none")
    else:
        for i, rec in enumerate(distinct_versions):
            print("  [%d] %s  %s  %s" % (
                i, rec["date"], human_size(rec["size"]), rec["md5"]
            ))
            print("      source: %s" % rec["path"])
    print("")

    print("Snapshot scan (most recent first):")
    for rec in snapshot_records:
        if rec["exists"]:
            version_index = "-"
            for i, drec in enumerate(distinct_versions):
                if drec["md5"] == rec["md5"]:
                    version_index = str(i)
                    break
            same_as_current = ""
            if current_record["exists"] and current_record["md5"] == rec["md5"]:
                same_as_current = "  SAME_AS_CURRENT"
            print("  %s  PRESENT  size=%s  version=%s  md5=%s%s" % (
                rec["date"], human_size(rec["size"]), version_index, rec["md5"], same_as_current
            ))
        else:
            print("  %s  MISSING" % rec["date"])


def restore_file_version(cwd, name, version_index):
    current_record, snapshot_records, distinct_versions = build_file_records(cwd, name)

    if version_index < 0 or version_index >= len(distinct_versions):
        eprint("Error: version index %d is out of range." % version_index)
        return 1

    chosen = distinct_versions[version_index]

    if chosen["where"] == "current":
        eprint("Error: version %d is the current file, not a snapshot version." % version_index)
        return 1

    restore_name = "%s.RESTORED.%s" % (name, chosen["date"].replace(" ", "_").replace(":", "-"))
    restore_path = os.path.join(cwd, restore_name)

    if os.path.exists(restore_path):
        eprint("Error: restore target already exists: %s" % restore_path)
        return 1

    shutil.copy2(chosen["path"], restore_path)

    print("Restored file version [%d]" % version_index)
    print("  Source snapshot: %s" % chosen["label"])
    print("  Source path: %s" % chosen["path"])
    print("  Restored to: %s" % restore_path)
    return 0


# ---------------- DIRECTORY MODE ----------------

def build_directory_current_record(cwd, dirname):
    path = os.path.join(cwd, dirname)
    if not os.path.isdir(path):
        return {
            "where": "current",
            "label": "CURRENT",
            "path": path,
            "exists": False,
            "date": "CURRENT",
            "files": {},
            "signature": None,
        }

    files = list_regular_files_nonrecursive(path)
    compute_md5_map(files)

    return {
        "where": "current",
        "label": "CURRENT",
        "path": path,
        "exists": True,
        "date": "CURRENT",
        "files": files,
        "signature": directory_signature(files),
    }


def directory_signature(files):
    parts = []
    for name in sorted(files.keys()):
        parts.append("%s:%s" % (name, files[name]["md5"]))
    joined = "\n".join(parts).encode("utf-8")
    return hashlib.md5(joined).hexdigest()


def compare_directory_file_maps(live_files, snap_files):
    live_names = set(live_files.keys())
    snap_names = set(snap_files.keys())

    common = live_names & snap_names
    only_in_live = sorted(live_names - snap_names)
    only_in_snapshot = sorted(snap_names - live_names)

    mismatch = []
    for name in sorted(common):
        if live_files[name]["md5"] != snap_files[name]["md5"]:
            mismatch.append(name)

    return {
        "live_files": len(live_names),
        "snap_files": len(snap_names),
        "file_count_diff": len(snap_names) - len(live_names),
        "md5_mismatch_count": len(mismatch),
        "only_in_live_count": len(only_in_live),
        "only_in_snapshot_count": len(only_in_snapshot),
        "mismatch_files": mismatch,
        "only_in_live": only_in_live,
        "only_in_snapshot": only_in_snapshot,
    }


def build_directory_records(cwd, dirname):
    current_record = build_directory_current_record(cwd, dirname)

    snapshot_records = []
    snapshot_dirs = list_snapshot_dirs(get_snapshot_root(cwd))
    for snap in snapshot_dirs:
        candidate_dir = os.path.join(snap["path"], dirname)
        if os.path.isdir(candidate_dir):
            files = list_regular_files_nonrecursive(candidate_dir)
            compute_md5_map(files)
            rec = {
                "where": "snapshot",
                "label": snap["name"],
                "path": candidate_dir,
                "exists": True,
                "date": snap["date"],
                "files": files,
                "signature": directory_signature(files),
            }
        else:
            rec = {
                "where": "snapshot",
                "label": snap["name"],
                "path": candidate_dir,
                "exists": False,
                "date": snap["date"],
                "files": {},
                "signature": None,
            }

        if current_record["exists"] and rec["exists"]:
            rec["comparison"] = compare_directory_file_maps(current_record["files"], rec["files"])
        else:
            rec["comparison"] = None

        snapshot_records.append(rec)

    distinct_versions = []
    seen_signatures = set()

    if current_record["exists"] and current_record["signature"] not in seen_signatures:
        distinct_versions.append(current_record)
        seen_signatures.add(current_record["signature"])

    for rec in snapshot_records:
        if not rec["exists"]:
            continue
        if rec["signature"] in seen_signatures:
            continue
        distinct_versions.append(rec)
        seen_signatures.add(rec["signature"])

    return current_record, snapshot_records, distinct_versions


def print_directory_check(cwd, dirname):
    current_record, snapshot_records, distinct_versions = build_directory_records(cwd, dirname)

    print("Type: directory")
    print("Target: %s" % dirname)
    print("Working directory: %s" % cwd)
    print("")
    print("Directory mode is non-recursive: only direct regular files are compared.")
    print("Subdirectories are ignored.")
    print("")

    if current_record["exists"]:
        print("Current directory: PRESENT")
        print("  Path: %s" % current_record["path"])
        print("  Direct regular files: %d" % len(current_record["files"]))
    else:
        print("Current directory: NOT PRESENT")
        print("  Path: %s" % current_record["path"])
    print("")

    print("Distinct directory versions available (most recent first):")
    if not distinct_versions:
        print("  none")
    else:
        for i, rec in enumerate(distinct_versions):
            count = len(rec["files"])
            print("  [%d] %s  files=%d  signature=%s" % (
                i, rec["date"], count, rec["signature"]
            ))
            print("      source: %s" % rec["path"])
    print("")

    print("Snapshot scan (most recent first):")
    for rec in snapshot_records:
        if not rec["exists"]:
            print("  %s  MISSING" % rec["date"])
            continue

        version_index = "-"
        for i, drec in enumerate(distinct_versions):
            if drec["signature"] == rec["signature"]:
                version_index = str(i)
                break

        same_as_current = ""
        if current_record["exists"] and current_record["signature"] == rec["signature"]:
            same_as_current = "  SAME_AS_CURRENT"

        if rec["comparison"] is None:
            print("  %s  PRESENT  files=%d  version=%s%s" % (
                rec["date"], len(rec["files"]), version_index, same_as_current
            ))
        else:
            comp = rec["comparison"]
            print(
                "  %s  PRESENT  version=%s  snap_files=%d  live_files=%d  file_count_diff=%+d  md5_mismatch_count=%d  only_in_live=%d  only_in_snapshot=%d%s"
                % (
                    rec["date"],
                    version_index,
                    comp["snap_files"],
                    comp["live_files"],
                    comp["file_count_diff"],
                    comp["md5_mismatch_count"],
                    comp["only_in_live_count"],
                    comp["only_in_snapshot_count"],
                    same_as_current
                )
            )


def restore_directory_version(cwd, dirname, version_index):
    current_record, snapshot_records, distinct_versions = build_directory_records(cwd, dirname)

    if version_index < 0 or version_index >= len(distinct_versions):
        eprint("Error: version index %d is out of range." % version_index)
        return 1

    chosen = distinct_versions[version_index]

    if chosen["where"] == "current":
        eprint("Error: version %d is the current directory, not a snapshot version." % version_index)
        return 1

    restore_dirname = "%s.RESTORED.%s" % (dirname, chosen["date"].replace(" ", "_").replace(":", "-"))
    restore_path = os.path.join(cwd, restore_dirname)

    if os.path.exists(restore_path):
        eprint("Error: restore target already exists: %s" % restore_path)
        return 1

    os.mkdir(restore_path)

    copied = 0
    for name in sorted(chosen["files"].keys()):
        src = chosen["files"][name]["path"]
        dst = os.path.join(restore_path, name)
        shutil.copy2(src, dst)
        copied += 1

    print("Restored directory version [%d]" % version_index)
    print("  Source snapshot: %s" % chosen["label"])
    print("  Source path: %s" % chosen["path"])
    print("  Restored to: %s" % restore_path)
    print("  Files copied: %d" % copied)
    print("  Note: non-recursive restore; subdirectories were ignored.")
    return 0


# ---------------- MAIN ----------------

def main():
    target, restore_index, parse_rc = parse_args(sys.argv)
    if parse_rc is not None:
        return parse_rc

    cwd = os.getcwd()

    if os.path.basename(target) != target:
        eprint("Error: please provide a file or directory name in the current directory only, not a path.")
        return 1

    current_path = os.path.join(cwd, target)

    if os.path.isfile(current_path):
        if restore_index is None:
            print_file_check(cwd, target)
            return 0
        return restore_file_version(cwd, target, restore_index)

    if os.path.isdir(current_path):
        if restore_index is None:
            print_directory_check(cwd, target)
            return 0
        return restore_directory_version(cwd, target, restore_index)

    # If missing in current dir, infer type from snapshots
    snapshot_dirs = list_snapshot_dirs(get_snapshot_root(cwd))
    found_file = False
    found_dir = False
    for snap in snapshot_dirs:
        spath = os.path.join(snap["path"], target)
        if os.path.isfile(spath):
            found_file = True
        if os.path.isdir(spath):
            found_dir = True

    if found_file and found_dir:
        eprint("Error: target appears as both file and directory across snapshots: %s" % target)
        return 1

    if found_file:
        if restore_index is None:
            print_file_check(cwd, target)
            return 0
        return restore_file_version(cwd, target, restore_index)

    if found_dir:
        if restore_index is None:
            print_directory_check(cwd, target)
            return 0
        return restore_directory_version(cwd, target, restore_index)

    eprint("Error: target not found in current directory or snapshots: %s" % target)
    return 1


if __name__ == "__main__":
    sys.exit(main())
